        "name": "Day mode start"
      },
      "night_mode_time": {
        "name": "Night mode start"
      }
    },
    "light": {
      "day_ambient_colour": {
        "name": "Day ambient colour"
      },
      "night_ambient_colour": {
        "name": "Night ambient colour"
      }
